.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
  margin-right: 16rpx;
}

.card-info {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #888888;
}

.card-divider {
  margin: 0 10rpx;
  color: #CCCCCC;
}

.card-meta {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #666666;
}

.card-scene {
  background: #FFF0EA;
  color: #FF6B35;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
  font-size: 22rpx;
}

.card-reviews {
  color: #999999;
  font-size: 22rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
}

.card-tag {
  background: #F0F0F0;
  color: #666666;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  font-size: 22rpx;
}

.card-risk {
  margin-bottom: 10rpx;
}

.risk-flag {
  color: #E53935;
  font-size: 22rpx;
  display: block;
  margin-bottom: 4rpx;
}

.card-summary {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
