.card {
  background: linear-gradient(135deg, #FFFEFC 0%, #F6F3EB 100%);
  border: 2rpx solid #E8E0D5;
  border-radius: 8rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-name {
  font-size: 38rpx;
  font-weight: bold;
  color: #3A332E;
  flex: 1;
  margin-right: 16rpx;
}

.card-info {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #8C847D;
}

.card-divider {
  margin: 0 10rpx;
  color: #CCCCCC;
}

.card-meta {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #666666;
}

.card-scene {
  background: transparent;
  color: #B86B52;
  border: 2rpx solid #B86B52;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  margin-right: 16rpx;
  font-size: 24rpx;
}

.card-reviews {
  color: #999999;
  font-size: 24rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
}

.card-tag {
  background: transparent;
  color: #8C847D;
  border: 2rpx solid #E8E0D5;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  font-size: 24rpx;
}

.card-risk {
  margin-bottom: 10rpx;
}

.risk-flag {
  color: #9E4730;
  font-size: 24rpx;
  display: block;
  margin-bottom: 4rpx;
}

.card-summary {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
