.filter-picker {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.filter-group {
  margin-bottom: 20rpx;
}

.filter-group:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
  display: block;
}

.filter-tags {
  white-space: nowrap;
}

.tag {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  margin-bottom: 8rpx;
  border-radius: 32rpx;
  background: #F5F5F5;
  color: #666666;
  font-size: 26rpx;
}

.tag-active {
  background: #FFF0EA;
  color: #FF6B35;
  font-weight: 600;
}
