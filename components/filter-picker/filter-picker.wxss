.filter-picker {
  background: linear-gradient(135deg, #FFFEFC 0%, #F6F3EB 100%);
  border: 2rpx solid #E8E0D5;
  border-radius: 8rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.04);
}

.filter-group {
  margin-bottom: 20rpx;
}

.filter-group:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #3A332E;
  margin-bottom: 16rpx;
  display: block;
}

.filter-tags {
  white-space: nowrap;
}

.tag {
  display: inline-block;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  margin-bottom: 8rpx;
  border-radius: 4rpx;
  background: transparent;
  border: 2rpx solid #E8E0D5;
  color: #8C847D;
  font-size: 28rpx;
}

.tag-active {
  background: transparent;
  border: 2rpx solid #B86B52;
  color: #B86B52;
  font-weight: bold;
}

.custom-budget {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  gap: 12rpx;
}

.budget-input {
  flex: 1;
  height: 64rpx;
  border: 2rpx solid #E8E0D5;
  border-radius: 4rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #3A332E;
  text-align: center;
}

.budget-sep {
  color: #8C847D;
  font-size: 28rpx;
}

.budget-unit {
  color: #8C847D;
  font-size: 28rpx;
}
