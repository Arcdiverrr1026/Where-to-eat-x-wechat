.review-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.review-time {
  font-size: 22rpx;
  color: #999999;
}

.review-content-wrap {
  position: relative;
}

.review-content {
  font-size: 26rpx;
  color: #444444;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.review-expanded {
  -webkit-line-clamp: unset;
  overflow: visible;
}

.review-toggle {
  font-size: 24rpx;
  color: #FF6B35;
  margin-top: 8rpx;
  display: inline-block;
}
