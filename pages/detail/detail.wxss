.page-detail {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.info-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.info-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.info-tone {
  font-size: 24rpx;
  color: #FF6B35;
  background: #FFF0EA;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  display: inline-block;
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 26rpx;
}

.info-label {
  color: #999999;
  width: 80rpx;
  flex-shrink: 0;
}

.info-value {
  color: #555555;
  flex: 1;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.sub-title {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 8rpx;
  margin-top: 12rpx;
  display: block;
}

.tags-section,
.risk-section,
.sentiment-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  background: #F0F0F0;
  color: #666666;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.risk-item {
  color: #E53935;
  font-size: 24rpx;
  display: block;
  margin-bottom: 6rpx;
}

.highlight-item {
  color: #2E7D32;
  font-size: 24rpx;
  display: block;
  margin-bottom: 6rpx;
}

.caution-item {
  color: #E65100;
  font-size: 24rpx;
  display: block;
  margin-bottom: 6rpx;
}

.map-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.detail-map {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
}

.navigate-btn {
  margin-top: 16rpx;
  text-align: center;
  padding: 16rpx;
  background: #FFF0EA;
  border-radius: 12rpx;
  color: #FF6B35;
  font-size: 28rpx;
  font-weight: 600;
}

.reviews-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
}

.reviews-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.write-review-btn {
  background: #FF6B35;
  color: #FFFFFF;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

/* 评价弹窗 */
.review-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.modal-content {
  background: #FFFFFF;
  width: 100%;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 24rpx;
}

.rating-input {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.rating-label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 16rpx;
}

.rating-stars {
  display: flex;
  gap: 16rpx;
}

.input-star {
  font-size: 48rpx;
  color: #DDDDDD;
}

.star-active {
  color: #FFB800;
}

.review-input {
  width: 100%;
  height: 200rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn-cancel {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
  color: #666666;
  font-size: 30rpx;
}

.modal-btn-submit {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #FF6B35;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-disabled {
  opacity: 0.5;
}
