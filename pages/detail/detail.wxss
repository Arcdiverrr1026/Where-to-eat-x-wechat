.page-detail {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.info-section {
  background: linear-gradient(135deg, #FFFEFC 0%, #F6F3EB 100%);
  border-radius: 8rpx;
  border: 2rpx solid #E8E0D5;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.04);
}

.info-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #3A332E;
  display: block;
  margin-bottom: 16rpx;
}

.info-tone {
  font-size: 26rpx;
  color: #B86B52;
  background: transparent;
  border: 2rpx solid #B86B52;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  display: inline-block;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  margin-bottom: 16rpx;
  font-size: 30rpx;
}

.info-label {
  color: #8C847D;
  width: 100rpx;
  flex-shrink: 0;
}

.info-value {
  color: #3A332E;
  flex: 1;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #3A332E;
  margin-bottom: 20rpx;
  display: block;
}

.sub-title {
  font-size: 30rpx;
  color: #8C847D;
  margin-bottom: 12rpx;
  margin-top: 24rpx;
  display: block;
}

.tags-section,
.risk-section,
.sentiment-section {
  background: linear-gradient(135deg, #FFFEFC 0%, #F6F3EB 100%);
  border-radius: 8rpx;
  border: 2rpx solid #E8E0D5;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.04);
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  background: transparent;
  border: 2rpx solid #E8E0D5;
  color: #8C847D;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-size: 26rpx;
}

.risk-item {
  color: #9E4730;
  font-size: 26rpx;
  display: block;
  margin-bottom: 10rpx;
}

.highlight-list,
.caution-list {
  margin-top: 8rpx;
}

.highlight-item {
  color: #556B2F;
  font-size: 26rpx;
  display: block;
  margin-bottom: 10rpx;
}

.caution-item {
  color: #9E4730;
  font-size: 26rpx;
  display: block;
  margin-bottom: 10rpx;
}

.map-section {
  background: linear-gradient(135deg, #FFFEFC 0%, #F6F3EB 100%);
  border-radius: 8rpx;
  border: 2rpx solid #E8E0D5;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.04);
}

.detail-map {
  width: 100%;
  height: 480rpx;
  border-radius: 8rpx;
}

.navigate-btn {
  margin-top: 24rpx;
  text-align: center;
  padding: 16rpx;
  background: transparent;
  border: 2rpx solid #B86B52;
  border-radius: 8rpx;
  color: #B86B52;
  font-size: 30rpx;
  font-weight: 500;
}

.reviews-section {
  background: linear-gradient(135deg, #FFFEFC 0%, #F6F3EB 100%);
  border-radius: 8rpx;
  border: 2rpx solid #E8E0D5;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.04);
}

.reviews-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.write-review-btn {
  background: #B86B52;
  color: #FFFFFF;
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* 评价弹窗 */
.review-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.modal-content {
  background: #FDFBF7;
  width: 100%;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.modal-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #3A332E;
  display: block;
  margin-bottom: 32rpx;
}

.rating-input {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.rating-label {
  font-size: 30rpx;
  color: #8C847D;
  margin-right: 16rpx;
}

.rating-stars {
  display: flex;
  gap: 16rpx;
}

.input-star {
  font-size: 56rpx;
  color: #E8E0D5;
}

.star-active {
  color: #B86B52;
}

.review-input {
  width: 100%;
  height: 240rpx;
  border: 2rpx solid #E8E0D5;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #3A332E;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-btn-cancel {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 8rpx;
  border: 2rpx solid #E8E0D5;
  background: transparent;
  color: #8C847D;
  font-size: 32rpx;
}

.modal-btn-submit {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 8rpx;
  background: #B86B52;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-disabled {
  opacity: 0.5;
}
