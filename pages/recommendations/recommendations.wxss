.page-recommendations {
  padding: 24rpx;
  min-height: 100vh;
}

.filter-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.summary-tag {
  background: transparent;
  border: 2rpx solid #B86B52;
  color: #B86B52;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-size: 26rpx;
}

.result-count {
  font-size: 26rpx;
  color: #8C847D;
  margin-bottom: 16rpx;
}

.loading-hint-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0 16rpx;
}

.loading-spinner-small {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #E8E0D5;
  border-top: 3rpx solid #B86B52;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: spin 0.8s linear infinite;
}

.loading-hint-text {
  font-size: 26rpx;
  color: #8C847D;
}

.skeleton-card {
  background: #FFFFFF;
  border-radius: 8rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.skeleton-line {
  background: linear-gradient(90deg, #F0EBE3 25%, #E8E0D5 50%, #F0EBE3 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 4rpx;
}

.skeleton-title {
  width: 60%;
  height: 36rpx;
  margin-bottom: 16rpx;
}

.skeleton-sub {
  width: 40%;
  height: 28rpx;
  margin-bottom: 20rpx;
}

.skeleton-row {
  display: flex;
  gap: 12rpx;
}

.skeleton-tag {
  width: 120rpx;
  height: 28rpx;
}

.skeleton-desc {
  width: 100%;
  height: 24rpx;
  margin-top: 16rpx;
}

.skeleton-desc-short {
  width: 70%;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
