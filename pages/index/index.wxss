.page-index {
  padding: 0 40rpx 60rpx;
  min-height: 100vh;
}

.hero {
  padding: 100rpx 0 60rpx;
}

.hero-greeting {
  display: block;
  font-size: 36rpx;
  color: #888888;
  margin-bottom: 16rpx;
}

.hero-title {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  color: #2C2C2C;
  line-height: 1.3;
}

.filter-section {
  margin-bottom: 60rpx;
}

.btn-search {
  margin-top: 20rpx;
}

.tips {
  text-align: center;
  margin-top: 40rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #BBBBBB;
  letter-spacing: 2rpx;
}
